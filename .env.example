# ── Server ────────────────────────────────────────────────────────────────────
# Port to listen on (default: 3000)
PORT=3000

# Database path (default: /app/data/navilist.db)
# Override for local dev outside Docker:
# DB_PATH=./data/navilist.db
DB_PATH=
NL_NSP_PATH=

# Data directory for logs and artist images (default: /app/data)
# Override for local dev outside Docker:
# DATA_DIR=./data
DATA_DIR=

NL_NSP_PATH=

# ── Navidrome ─────────────────────────────────────────────────────────────────
# These seed the settings DB on first boot only.
# Once saved via the UI, UI values take precedence.
NAVIDROME_URL=
NAVIDROME_USER=
NAVIDROME_PASSWORD=

# Comma-separated music folder IDs to sync (leave blank to sync all)
MUSIC_FOLDER_IDS=

# ── Last.fm ───────────────────────────────────────────────────────────────────
LASTFM_API_KEY=
LASTFM_USERNAME=

# ── ListenBrainz ──────────────────────────────────────────────────────────────
LISTENBRAINZ_TOKEN=
LISTENBRAINZ_USERNAME=

# ── Lidarr ────────────────────────────────────────────────────────────────────
# URL of your Lidarr instance
LIDARR_URL=
# Lidarr API key (Settings → General → Security)
LIDARR_API_KEY=
# Root folder path for new artists (e.g. /music)
# Leave blank and configure via the Settings page instead
LIDARR_ROOT_FOLDER=
# Quality profile ID — use Settings page to pick from a dropdown
LIDARR_QUALITY_PROFILE_ID=
# Metadata profile ID — use Settings page to pick from a dropdown
LIDARR_METADATA_PROFILE_ID=
